    "test": "node --test"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@scure/bip39": "^2.2.0",
    "assert": "^2.1.0",
    "buffer": "^6.0.3",
    "esbuild": "^0.28.1",
    "ethers": "^6.13.0",
    "events": "^3.3.0",
    "process": "^0.11.10",
    "tweetnacl": "^1.0.3"
  }
}
