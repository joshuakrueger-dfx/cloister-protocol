# Cloister Console — build-time configuration (Vite).
# Copy to `.env.production` (or set in the build environment) and fill in.
# With NONE of these set, the app builds as the self-contained Demo (mock data),
# which is the safe default for the hosted preview.

# ── DFX (KYC + on-ramp) ────────────────────────────────────────────────
# Production:  https://api.dfx.swiss        KYC page: https://app.dfx.swiss/kyc
# Sandbox:     https://dev.api.dfx.swiss    KYC page: https://dev.app.dfx.swiss/kyc
# Leave unset to use production defaults.
VITE_DFX_API_URL=https://api.dfx.swiss
VITE_DFX_KYC_URL=https://app.dfx.swiss/kyc

# ── Cloister backend (provider / relayer / indexer) ────────────────────
# Setting VITE_API_URL adds a "Production" backend AND makes it the default
# (instead of Demo). Point it at the deployed provider that serves /config,
# /v1/shield, /v1/kyc/screen and the relayer/indexer URLs.
# Leave unset to ship the Demo backend.
# VITE_API_URL=https://api.cloister-protocol.com
# VITE_API_LABEL=Production
# VITE_API_META=Base mainnet
